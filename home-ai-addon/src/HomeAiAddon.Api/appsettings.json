{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    },
    "FilePath": "./data/logs/home-ai-.log"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=./data/app.db"
  },
  "HomeAssistant": {
    "BaseUrl": ""
  },
  "BehaviorAnalysis": {
    "BaseUrl": "http://127.0.0.1:8100",
    "TimeoutSeconds": 120,
    "EventLimit": 2500,
    "MinSupport": 3,
    "MinConfidence": 0.55,
    "MaxGapSeconds": 300,
    "MaxSequenceLength": 4,
    "LookbackHours": 168
  }
}
