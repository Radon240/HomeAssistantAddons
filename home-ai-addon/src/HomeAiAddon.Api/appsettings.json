{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore.Database.Command": "Warning"
    },
    "FilePath": "./data/logs/home-ai-.log"
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "Default": "Data Source=./data/app.db"
  },
  "HomeAssistant": {
    "BaseUrl": ""
  },
  "BehaviorAnalysis": {
    "BaseUrl": "http://127.0.0.1:8100",
    "TimeoutSeconds": 120,
    "EventLimit": 2500,
    "MinSupport": 3,
    "MinConfidence": 0.55,
    "MinCadenceConfidence": 0.4,
    "RequirePeriodic": false,
    "MaxGapSeconds": 300,
    "MaxSequenceLength": 4,
    "LookbackHours": 336,
    "FeedbackDismissDays": 14,
    "MinLift": 1.2,
    "MinSupportRatio": 0.03,
    "MaxStepGapSeconds": 180
  },
  "AnomalyDetection": {
    "Enabled": true,
    "IntervalMinutes": 15,
    "EventLimit": 3000,
    "RetentionDays": 30,
    "ListLimit": 100,
    "MinEvents": 50,
    "MinEventsPerEntity": 8,
    "MinHourlySamples": 4,
    "RollingWindowHours": 24,
    "ZScoreThreshold": 2.5,
    "UnusualHourMaxRatio": 0.05,
    "MinNumericDelta": 0.5,
    "MinScore": 0.55,
    "MediumSeverityThreshold": 0.7,
    "HighSeverityThreshold": 0.85,
    "MaxResults": 30,
    "IsolationForestEstimators": 50,
    "IsolationForestContamination": 0.08,
    "IsolationForestMinSamples": 20
  }
}
